# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Resend Email API
RESEND_API_KEY=re_your-key
# Verified sending domain — set to: Paybacker <hello@paybacker.co.uk>
RESEND_FROM_EMAIL=Paybacker <hello@paybacker.co.uk>

# Application Configuration
NEXT_PUBLIC_APP_URL=https://paybacker.co.uk
NODE_ENV=development

# Cron job authentication (generate a random secret, set same value in Vercel)
CRON_SECRET=your-cron-secret

# Token encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-string

# Open Banking Provider toggle: 'truelayer' or 'yapily' (default: truelayer)
OPEN_BANKING_PROVIDER=truelayer
NEXT_PUBLIC_OPEN_BANKING_PROVIDER=truelayer

# TrueLayer Open Banking
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
# Local dev: http://localhost:3000/api/auth/callback/truelayer
# Production: https://paybacker.co.uk/api/auth/callback/truelayer
TRUELAYER_REDIRECT_URI=https://paybacker.co.uk/api/auth/callback/truelayer
# Sandbox testing:
# TRUELAYER_AUTH_URL=https://auth.truelayer-sandbox.com
# TRUELAYER_API_URL=https://api.truelayer-sandbox.com
# Production:
TRUELAYER_AUTH_URL=https://auth.truelayer.com
TRUELAYER_API_URL=https://api.truelayer.com

# Meta (Facebook + Instagram) Social API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=  # Long-lived page access token
META_PAGE_ID=       # Facebook Page ID
META_INSTAGRAM_ACCOUNT_ID=  # Instagram Business Account ID (linked to FB page)

# Telegram Bots
# @Paybackercoukbot — customer-facing Pocket Agent (Pro subscribers)
# Webhook: /api/telegram/webhook
TELEGRAM_BOT_TOKEN=                    # @Paybackercoukbot token from @BotFather
TELEGRAM_ALLOWED_CHAT_IDS=             # Comma-separated chat IDs allowed on the customer bot
TELEGRAM_USER_WEBHOOK_SECRET=          # Secret token for user-webhook validation

# @PaybackerAssistantBot — founder admin command centre (Charlie EA)
# Webhook: /api/telegram/admin-command
# Register with: curl "https://api.telegram.org/bot<ADMIN_TOKEN>/setWebhook?url=https://paybacker.co.uk/api/telegram/admin-command"
TELEGRAM_ADMIN_BOT_TOKEN=              # @PaybackerAssistantBot token from @BotFather
TELEGRAM_FOUNDER_CHAT_ID=1003645878    # Paul's Telegram chat ID
