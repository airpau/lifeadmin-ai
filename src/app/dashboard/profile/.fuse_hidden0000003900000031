          { label: 'Name', filled: !!profile?.full_name },
          { label: 'Phone', filled: !!profile?.phone },
          { label: 'Address', filled: !!profile?.address },
          { label: 'Postcode', filled: !!profile?.postcode },
        ];
        const filledCount = fields.filter(f => f.filled).length;
