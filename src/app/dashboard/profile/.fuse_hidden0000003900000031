  // Fetch saved reports for Pro users
  useEffect(() => {
    const isPro = profile?.subscription_tier &&
      profile.subscription_tier === 'pro' &&
      ['active', 'trialing'].includes(profile?.subscription_status ?? '');
    if (profile && isPro) {
