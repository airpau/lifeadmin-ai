    return (
      <span className={`px-3 py-1 rounded-full text-sm font-semibold border ${colors[effectiveTier as keyof typeof colors]}`}>
        {effectiveTier.charAt(0).toUpperCase() + effectiveTier.slice(1)}
      </span>
    );
  };

  const subscriptionStatusLabel = () => {
