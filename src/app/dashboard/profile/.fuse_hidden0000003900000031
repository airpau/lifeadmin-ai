    if (status === 'past_due') {
      return <span className="text-red-400 font-semibold">{tierLabel} — Payment overdue</span>;
    }
    if (status === 'canceled') {
      return <span className="text-slate-600 font-semibold">{tierLabel} — Cancelled</span>;
